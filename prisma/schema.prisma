// Cinema Ticket Management System - Database Schema
// Using Prisma ORM with SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model - Stores user account information
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("CUSTOMER") // ADMIN, CUSTOMER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("users")
}

// Movie model - Stores film information
model Movie {
  id          String   @id @default(cuid())
  title       String
  poster      String?
  trailer     String?
  description String?
  director    String?
  cast        String?
  genre       String
  duration    Int      // Duration in minutes
  rating      Float?
  language    String   @default("Vietnamese")
  status      String   @default("NOW_SHOWING") // COMING_SOON, NOW_SHOWING, ENDED
  releaseDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  showtimes Showtime[]

  @@map("movies")
}

// Room model - Cinema hall/auditorium
model Room {
  id           String   @id @default(cuid())
  name         String
  rows         Int      // Number of rows
  seatsPerRow  Int      // Seats per row
  roomType     String   @default("STANDARD") // STANDARD, VIP, IMAX, THREE_D
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  showtimes Showtime[]

  @@map("rooms")
}

// Showtime model - Scheduled screening time
model Showtime {
  id        String   @id @default(cuid())
  movieId   String
  roomId    String
  startTime DateTime
  endTime   DateTime // Calculated from startTime + movie duration
  price     Float    // Base price
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie   Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  seats   Seat[]
  bookings Booking[]

  @@index([movieId])
  @@index([roomId])
  @@index([startTime])
  @@map("showtimes")
}

// Seat model - Individual seat in a room
model Seat {
  id          String @id @default(cuid())
  showtimeId  String
  row         String // Row identifier (A, B, C, etc.)
  number      Int    // Seat number within row
  type        String @default("STANDARD") // STANDARD, VIP
  price       Float  // Individual seat price

  showtime    Showtime      @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  bookingSeats BookingSeat[]

  @@unique([showtimeId, row, number])
  @@map("seats")
}

// Booking model - Customer ticket order
model Booking {
  id            String   @id @default(cuid())
  userId        String
  showtimeId    String
  totalAmount   Float
  status        String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, EXPIRED
  paymentId     String?  @unique
  qrCode        String?  // QR code for ticket
  bookingCode   String   @unique // Human readable booking code
  expiresAt     DateTime // Payment expiration time
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  showtime   Showtime     @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  payment    Payment?
  bookingSeats BookingSeat[]

  @@index([userId])
  @@index([showtimeId])
  @@index([status])
  @@map("bookings")
}

// BookingSeat model - Junction table for booking and seats
model BookingSeat {
  id        String   @id @default(cuid())
  bookingId String
  seatId    String
  price     Float    // Price at time of booking
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat    Seat    @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@unique([bookingId, seatId])
  @@map("booking_seats")
}

// Payment model - Payment transaction records
model Payment {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  amount          Float
  method          String    // CREDIT_CARD, MOMO, ZALO_PAY, VNPAY, CASH
  status          String    @default("PENDING") // PENDING, PROCESSING, SUCCESS, FAILED, REFUNDED
  transactionId   String?   @unique // From payment gateway
  paymentData     String?   // JSON data from payment gateway
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}
